  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?

  clinic         Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient        Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  capturedByUser User    @relation("ClinicalPhotoCapturedBy", fields: [capturedBy], references: [id])

  @@index([clinicId, patientId, module])
  @@index([clinicId, patientId, photoType])
  @@index([patientId, capturedAt(sort: Desc)])
  @@index([clinicId, deletedAt])
  @@map("clinical_photos")
}

// ── ClinicalEvolutionTemplate ───────────────────────────────────────────────
//
// Plantilla SOAP por módulo + clínica. soapTemplate guarda 4 strings con
// placeholders {{patient.firstName}} etc. proceduresPrefilled: lista de
// IDs de ProcedureCatalog. materialsPrefilled: lista de InventoryItem IDs.
model ClinicalEvolutionTemplate {
  id                  String         @id @default(cuid())
  clinicId            String
  module              ClinicalModule
  name                String
  soapTemplate        Json // { S: string; O: string; A: string; P: string }
  proceduresPrefilled String[]       @default([])
  materialsPrefilled  String[]       @default([])
  isDefault           Boolean        @default(false)
  createdBy           String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  clinic        Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdByUser User   @relation("EvolutionTemplateCreatedBy", fields: [createdBy], references: [id])

  @@unique([clinicId, module, name])
  @@index([clinicId, module, isDefault])
  @@map("clinical_evolution_templates")
}

// ── DoctorContact ───────────────────────────────────────────────────────────
//
// Contactos de doctores externos para hojas de referencia. La cédula
// profesional es opcional pero recomendada para que aparezca en el PDF.
model DoctorContact {
  id         String    @id @default(cuid())
  clinicId   String
  fullName   String
  specialty  String?
  cedula     String?
  phone      String?
  email      String?
  clinicName String?
  address    String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  clinic          Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  referralLetters ReferralLetter[]

  @@index([clinicId, fullName])
  @@map("doctor_contacts")
}

// ── ReferralLetter ──────────────────────────────────────────────────────────
//
// Hoja de referencia/interconsulta. summary se pre-llena desde el módulo
// origen (edad, dx, hábitos, alergias). pdfUrl apunta al PDF generado y
// guardado en PatientFile. status trackea ciclo: draft → sent → completed.
model ReferralLetter {
  id             String                 @id @default(cuid())
  clinicId       String
  patientId      String
  module         ClinicalModule
  contactId      String?
  authorId       String
  reason         String
  summary        String                 @db.Text
  pdfUrl         String?
  status         ReferralLetterStatus   @default(draft)
  sentAt         DateTime?
  sentChannel    ReferralLetterChannel?
  acknowledgedAt DateTime?
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?

  clinic  Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  author  User           @relation("ReferralLetterAuthor", fields: [authorId], references: [id])
  contact DoctorContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([clinicId, patientId, module])
  @@index([clinicId, status])
  @@map("referral_letters")
}

// ── LabPartner ──────────────────────────────────────────────────────────────
//
// Laboratorio externo asociado a la clínica. Se reutiliza por todas las
// LabOrder del clinicId.
model LabPartner {
  id          String    @id @default(cuid())
  clinicId    String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  clinic    Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  labOrders LabOrder[]

  @@index([clinicId, isActive])
  @@map("lab_partners")
}

// ── LabOrder ────────────────────────────────────────────────────────────────
//
// Orden de laboratorio polimórfica por módulo. spec guarda detalles
// específicos por orderType (Json libre). pdfUrl apunta al PDF generado.
model LabOrder {
  id         String         @id @default(cuid())
  clinicId   String
  patientId  String
  module     ClinicalModule
  partnerId  String?
  authorId   String
  orderType  LabOrderType
  spec       Json
  toothFdi   Int?
  shadeGuide String?
  dueDate    DateTime?
  pdfUrl     String?
  status     LabOrderStatus @default(draft)
  sentAt     DateTime?
  receivedAt DateTime?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  clinic  Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  author  User        @relation("LabOrderAuthor", fields: [authorId], references: [id])
  partner LabPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([clinicId, patientId, module])
  @@index([clinicId, status])
  @@map("lab_orders")
}

// ── TreatmentLink ───────────────────────────────────────────────────────────
//
// Une una sesión específica de un módulo (eg. un Sealant aplicado, una
// FluorideApplication, un EndodonticTreatment) con una TreatmentSession
// del plan general (TreatmentPlan). Cuando se crea, marca la
// TreatmentSession como completada (completedAt = now()).
//
// moduleEntityType es el nombre lógico (eg. "ped-sealant", "endo-treatment").
// moduleSessionId es el id del registro del módulo. Tabla polimórfica:
// no hay FK al moduleSessionId — la consistencia se garantiza por las
// server actions que crean los links.
model TreatmentLink {
  id                 String         @id @default(cuid())
  clinicId           String
  module             ClinicalModule
  moduleEntityType   String
  moduleSessionId    String
  treatmentSessionId String
  linkedBy           String
  notes              String?
  createdAt          DateTime       @default(now())
  deletedAt          DateTime?

  clinic           Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  treatmentSession TreatmentSession @relation(fields: [treatmentSessionId], references: [id], onDelete: Cascade)
  author           User             @relation("TreatmentLinkAuthor", fields: [linkedBy], references: [id])

  @@unique([moduleEntityType, moduleSessionId, treatmentSessionId])
  @@index([clinicId, treatmentSessionId])
  @@index([clinicId, module])
  @@map("treatment_links")
}

// ── PatientShareLink ────────────────────────────────────────────────────────
//
// Token público con expiración (default 30d) para que el paciente vea un
// resumen del módulo en /share/p/[token]. revokedAt opcional para invalidar.
model PatientShareLink {
  id         String         @id @default(cuid())
  clinicId   String
  patientId  String
  module     ClinicalModule
  token      String         @unique
  expiresAt  DateTime
  createdBy  String
  viewCount  Int            @default(0)
  lastViewed DateTime?
  revokedAt  DateTime?
  createdAt  DateTime       @default(now())

  clinic        Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient       Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdByUser User    @relation("PatientShareLinkCreator", fields: [createdBy], references: [id])

  @@index([clinicId, patientId, module])
  @@index([expiresAt])
  @@map("patient_share_links")
}

// ── ClinicalReminder ────────────────────────────────────────────────────────
//
// Recordatorio clínico programado (no es lo mismo que Reminder existente
// que es manual). Cada recordatorio representa una tarea recurrente o
// puntual: control de erupción anual, profilaxis 6m, cumpleaños, etc.
// El cron diario (06:00 MX) detecta los con dueDate <= today + 7 y crea
// WhatsAppReminder con la plantilla correspondiente.
model ClinicalReminder {
  id                 String                 @id @default(cuid())
  clinicId           String
  patientId          String
  module             ClinicalModule
  reminderType       ClinicalReminderType
  dueDate            DateTime
  status             ClinicalReminderStatus @default(pending)
  message            String?
  payload            Json?
  whatsappReminderId String?
  triggeredAt        DateTime?
  completedAt        DateTime?
  createdBy          String
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deletedAt          DateTime?

  clinic        Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient       Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdByUser User    @relation("ClinicalReminderCreator", fields: [createdBy], references: [id])

  @@index([clinicId, patientId, module])
  @@index([status, dueDate])
  @@index([reminderType, status])
  @@map("clinical_reminders")
}
