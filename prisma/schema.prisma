  @@index([clinicId])
  @@index([planId])
  @@map("periodontal_surgeries")
}

// El modelo `Implant` vive en `feature/implant-module-v1` (módulo 4/5).
// A2 cross-módulos NO lo redefine — solo agrega la FK desde
// PeriImplantAssessment.implantId → implants.id (ALTER TABLE en migración)
// y las reverse relations Patient.implants / Clinic.implants /
// User.implantsPlaced que coinciden con las del módulo real.
//
// Esta rama A2 NO es deployable standalone: la migración asume que la
// tabla `implants` existe (creada por el módulo Implantología). El merge
// efectivo se hace vía `feature/implant-phase-8-v1` que ya parte de
// `origin/feature/implant-module-v1`.

model PeriImplantAssessment {
  id        String @id @default(cuid())
  patientId String
  clinicId  String

  // FK opcional al modelo Implant (módulo 4/5). Se mantiene nullable
  // para preservar assessments antiguos que no tienen un Implant
  // referenciado. La FK de SQL la agrega la migración
  // 20260505100000_dental_cross_modules.
  implantId  String?
  implantFdi Int

  status                 PeriImplantStatus
  bop                    Boolean
  suppuration            Boolean
  radiographicBoneLossMm Float?
  recommendedTreatment   String?

  evaluatedAt   DateTime @default(now())
  evaluatedById String
  evaluatedBy   User     @relation(fields: [evaluatedById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  patient Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic  Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  implant Implant? @relation("ImplantPeriAssessments", fields: [implantId], references: [id], onDelete: SetNull)

  @@index([patientId, evaluatedAt(sort: Desc)])
  @@index([clinicId, status])
  @@index([implantId])
  @@map("peri_implant_assessments")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORTHODONTICS MODULE v2 — feat/ortho-v2-rewrite
// 17 modelos + 15 enums conformes a docs/ortho-redesign-v2/SPEC.md
//
// Renames vs SPEC (registrados en docs/ortho-redesign-v2/_decisions.md):
//   - SPEC `TreatmentPlan` → `OrthoTreatmentPlan` (legacy TreatmentPlan
//     cross-módulo en línea 895 preservado para perio/implants/clinical-shared)
//   - SPEC `LabOrder` → `OrthoLabOrder` (LabOrder cross-módulo en línea 5306
//     intacto)
//   - SPEC `LabOrderStatus` → `OrthoLabOrderStatus` (colisión con enum
//     cross-módulo de línea 5306)
//
// Sin FK a `Xray` (modelo no existe en schema actual — RX se modelan como
// `Photo.kind = RX_*`). Re-cablear en Fase 4 si surge `Xray` global.
// ─────────────────────────────────────────────────────────────────────────────

