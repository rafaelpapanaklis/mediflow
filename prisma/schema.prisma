model ResourceBooking {
  id            String   @id @default(cuid())
  clinicId      String
  appointmentId String?
  resourceType  String
  resourceName  String
  startTime     DateTime
  endTime       DateTime
  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, resourceType, startTime])
  @@map("resource_bookings")
}

model ProcedureCatalog {
  id          String    @id @default(cuid())
  clinicId    String
  name        String
  code        String? // SAT code for CFDI
  /// NOM-024 — código clínico CIE-9-MC del procedimiento (separado del SAT)
  cieCode     String?   @db.VarChar(8)
  category    String // "general", "dental", "aesthetic", etc.
  basePrice   Float
  duration    Int? // minutes
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  clinic      Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  cie9        Cie9Code? @relation(fields: [cieCode], references: [code])

  @@index([clinicId, isActive])
  @@index([cieCode])
  @@map("procedure_catalog")
}

/// Catálogo CIE-9-MC OMS. Tabla GLOBAL. Seed inicial vía
/// POST /api/admin/seed-cie9 con TOP ~100 procedimientos comunes.
model Cie9Code {
  code        String @id @db.VarChar(8)
  description String @db.VarChar(500)
  category    String @db.VarChar(120)

  procedures ProcedureCatalog[]

  @@index([category])
  @@map("cie9_codes")
}

// ── Super-admin internal notes per clinic ─────────────────────────────
model AdminClinicNote {
  id        String   @id @default(cuid())
  clinicId  String
  authorId  String? // null = super admin (sin User record)
  content   String   @db.Text
  createdAt DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id])

  @@index([clinicId])
  @@map("admin_clinic_notes")
}

// ── Global announcements shown inside the dashboard ───────────────────
model AdminAnnouncement {
  id        String    @id @default(cuid())
  message   String    @db.Text
  type      String    @default("info") // info | warning | success | maintenance
  active    Boolean   @default(true)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("admin_announcements")
}

// ── Discount coupons applied to subscription payments ─────────────────
model Coupon {
  id         String    @id @default(cuid())
  code       String    @unique
  type       String // percentage | fixed
  value      Float
  validFrom  DateTime  @default(now())
  validUntil DateTime?
  maxUses    Int?
  usedCount  Int       @default(0)
  appliesTo  String    @default("all") // all | BASIC | PRO | CLINIC
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@map("coupons")
}

// ── Prescription (receta médica con QR verificable) ───────────────────
model Prescription {
  id               String    @id @default(cuid())
  medicalRecordId  String
  patientId        String
  doctorId         String
  clinicId         String
  medications      Json
  indications      String?   @db.Text
  qrCode           String    @unique
  verifyUrl        String
  issuedAt         DateTime  @default(now())
  expiresAt        DateTime?
  cofeprisGroup    String?
  cofeprisFolio    String?
  digitalSignature String?

  medicalRecord MedicalRecord      @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  patient       Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        User               @relation(fields: [doctorId], references: [id])
  clinic        Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  // NOM-024 (Compliance Fase B) — items estructurados con FK a CUMS.
  // El JSON `medications` legacy queda intacto para datos históricos.
  items         PrescriptionItem[]

  @@index([clinicId])
  @@index([patientId])
  @@index([medicalRecordId])
  @@index([clinicId, issuedAt(sort: Desc)])
  @@map("prescriptions")
}

/// Catálogo CUMS (Cuadro Único de Medicamentos del Sector Salud).
/// Tabla GLOBAL (sin clinicId) — es estándar público SSA.
model CumsItem {
  clave             String  @id @db.VarChar(20)
  descripcion       String  @db.VarChar(500)
  presentacion      String  @db.VarChar(200)
  formaFarmaceutica String? @db.VarChar(100)
  grupoTerapeutico  String? @db.VarChar(200)
  cofeprisGroup     String? @db.VarChar(20)

  prescriptions PrescriptionItem[]

  @@index([cofeprisGroup])
  @@index([grupoTerapeutico])
  @@map("cums_items")
}

/// Item de receta — un medicamento con dosage/duration/quantity.
/// Multi-tenant via relation prescription.clinicId.
model PrescriptionItem {
  id             String   @id @default(cuid())
  prescriptionId String
  cumsKey        String   @db.VarChar(20)
  dosage         String   @db.VarChar(200)
  duration       String?  @db.VarChar(100)
  quantity       String?  @db.VarChar(50)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  cums         CumsItem     @relation(fields: [cumsKey], references: [clave])

  @@index([prescriptionId])
  @@map("prescription_items")
}

// ═══════════════════════════════════════════════════════════
// Fase 4 — Agenda pro
// ═══════════════════════════════════════════════════════════

enum AppointmentSource {
  STAFF
  PATIENT_PORTAL
  WEBSITE
  WHATSAPP
}

/// Sillón / sala / equipo reservable.
model Resource {
  id         String       @id @default(cuid())
  clinicId   String
  name       String       @db.VarChar(120)
  kind       ResourceKind @default(CHAIR)
  color      String?      @db.VarChar(9)
  isActive   Boolean      @default(true)
  orderIndex Int          @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  cost         ResourceCost?

  @@index([clinicId, isActive, orderIndex])
}

enum ResourceKind {
  CHAIR
  ROOM
  EQUIPMENT
}

// ═══════════════════════════════════════════════════════════
// Mi Clínica Visual — layout isométrico 2.5D de la clínica
// ═══════════════════════════════════════════════════════════
//
// 1 layout por clínica. `elements` es un array JSON con:
//   { id: number, type: string, col: number, row: number, rotation: 0|90|180|270, resourceId?: string }
// Para tipos "chair" → resourceId apunta al Resource(kind=CHAIR) real;
// el editor solo coloca/posiciona el sillón existente, no crea uno nuevo.
// Para tipos non-chair (paredes, puertas, lavabos…) resourceId es null y el
// id es local al layout.
model ClinicLayout {
  id        String   @id @default(cuid())
  clinicId  String   @unique
  name      String   @default("Layout principal") @db.VarChar(120)
  elements  Json     @default("[]")
  metadata  Json? // { zoom, panOffset, lastEditAt, gridSize }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_layouts")
}

/// Lista de espera de pacientes que quieren adelantar su cita
/// si surge un hueco.
model WaitlistEntry {
  id                String           @id @default(cuid())
  clinicId          String
  patientId         String
  createdByUserId   String
  reason            String?          @db.VarChar(200)
  priority          WaitlistPriority @default(NORMAL)
  preferredDoctorId String?
  preferredWindow   String?          @db.VarChar(80)
  notes             String?          @db.VarChar(500)

  resolvedAt            DateTime? @db.Timestamptz(6)
  resolvedAppointmentId String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  clinic          Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient         Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy       User    @relation("WaitlistCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  preferredDoctor User?   @relation("WaitlistPreferredDoctor", fields: [preferredDoctorId], references: [id], onDelete: SetNull)

  @@index([clinicId, resolvedAt])
  @@index([patientId])
}

enum WaitlistPriority {
  LOW
  NORMAL
  HIGH
}

// ═══════════════════════════════════════════════════════════
// Fase 6 — Inbox unificado (WhatsApp + Email + Form + Validation + Reminder)
// ═══════════════════════════════════════════════════════════

enum InboxChannel {
  WHATSAPP
  EMAIL
  PORTAL_FORM
  VALIDATION
  REMINDER
}

enum InboxStatus {
  UNREAD
  READ
  ARCHIVED
  SNOOZED
}

enum MessageDirection {
  IN
  OUT
}

model InboxThread {
  id            String       @id @default(cuid())
  clinicId      String
  channel       InboxChannel
  /// ID en el sistema externo: Twilio Conversation SID, Postmark Message-ID, etc.
  externalId    String?
  patientId     String?
  subject       String
  status        InboxStatus  @default(UNREAD)
  assignedToId  String?
  snoozedUntil  DateTime?
  lastMessageAt DateTime
  tags          String[]     @default([])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  clinic     Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient    Patient?       @relation(fields: [patientId], references: [id], onDelete: SetNull)
  assignedTo User?          @relation("InboxAssignee", fields: [assignedToId], references: [id])
  messages   InboxMessage[]
  reminders  Reminder[]

  @@index([clinicId, status, lastMessageAt(sort: Desc)])
  @@index([clinicId, channel, lastMessageAt(sort: Desc)])
  @@index([assignedToId, status])
  @@index([snoozedUntil])
  @@map("inbox_threads")
}

model InboxMessage {
  id          String           @id @default(cuid())
  threadId    String
  direction   MessageDirection
  body        String           @db.Text
  attachments Json? // [{ name, url, mime, size }]
  sentAt      DateTime         @default(now())
  sentById    String?
  externalId  String?
  /// true = nota interna del staff (no se envía al canal externo).
  isInternal  Boolean          @default(false)

  thread InboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sentBy User?       @relation(fields: [sentById], references: [id])

  @@index([threadId, sentAt])
  @@map("inbox_messages")
}

enum ReminderStatus {
  PENDING
  DONE
  DISMISSED
}

model Reminder {
  id            String         @id @default(cuid())
  clinicId      String
  createdById   String
  assignedToId  String
  patientId     String?
  threadId      String?
  title         String
  body          String?        @db.Text
  dueAt         DateTime
  status        ReminderStatus @default(PENDING)
  completedAt   DateTime?
  completedById String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  clinic     Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdBy  User         @relation("ReminderCreator", fields: [createdById], references: [id])
  assignedTo User         @relation("ReminderAssignee", fields: [assignedToId], references: [id])
  patient    Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)
  thread     InboxThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@index([clinicId, status, dueAt])
  @@index([assignedToId, status, dueAt])
  @@index([dueAt])
  @@map("reminders")
}

// ═══════════════════════════════════════════════════════════════════
// Analytics & Insights — Push 1
// ═══════════════════════════════════════════════════════════════════

/// Línea de tiempo operativa de una cita. Capturamos timestamps en cada
/// transición de status (CHECKED_IN → IN_CHAIR → IN_PROGRESS → COMPLETED →
/// CHECKED_OUT) para alimentar reportes de ocupación, espera y journey.
/// totalWaitMin = inChairAt - arrivedAt; totalConsultMin = consultEndAt -
/// consultStartAt. Calculados en el endpoint que upserts el timeline.
model AppointmentTimeline {
  id              String    @id @default(cuid())
  appointmentId   String    @unique
  arrivedAt       DateTime? @db.Timestamptz(6)
  inChairAt       DateTime? @db.Timestamptz(6)
  consultStartAt  DateTime? @db.Timestamptz(6)
  consultEndAt    DateTime? @db.Timestamptz(6)
  checkoutAt      DateTime? @db.Timestamptz(6)
  totalWaitMin    Int?
  totalConsultMin Int?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_timelines")
}

/// Costos mensuales por sillón/recurso para calcular margen real
/// (renta + operativos vs ingresos generados por citas en ese sillón).
/// Editado por admin desde el form en /dashboard/analytics → Costos.
model ResourceCost {
  id          String   @id @default(cuid())
  resourceId  String   @unique
  monthlyRent Decimal  @default(0) @db.Decimal(10, 2)
  monthlyOps  Decimal  @default(0) @db.Decimal(10, 2)
  notes       String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@map("resource_costs")
}

/// Predicción de no-show generada por IA (Claude) basada en factores:
/// historial del paciente, día/hora, tipo procedimiento, tiempo desde
/// última cita. Persistimos para que el badge de la agenda no recalcule
/// cada render. Refresh manual o vía cron al crear cita.
model NoShowPrediction {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  probability   Float /// 0.0 a 1.0
  factors       Json /// Array de { label: string, weight: number, reason: string }
  predictedAt   DateTime @default(now()) @db.Timestamptz(6)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([predictedAt])
  @@map("no_show_predictions")
}

/// Resumen semanal generado por IA cada domingo 22:00 (cron). Bullets
/// accionables comparando esta semana vs anterior. Notificación in-app
/// (NO email). El usuario marca read=true al abrir el insight.
model WeeklyInsight {
  id        String   @id @default(cuid())
  clinicId  String
  weekStart DateTime @db.Timestamptz(6)
  weekEnd   DateTime @db.Timestamptz(6)
  summary   String   @db.VarChar(500) /// 1-2 oraciones top-line
  insights  Json /// Array de { tone, title, detail }
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, weekStart])
  @@map("weekly_insights")
}

/// NPS post-cita 1-5. Capturado vía portal del paciente o link en
/// recordatorio WA. Alimenta el promedio de satisfacción del doctor.
model PatientSatisfaction {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  score         Int /// 1-5
  comment       String?  @db.VarChar(1000)
  submittedAt   DateTime @default(now()) @db.Timestamptz(6)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([submittedAt])
  @@map("patient_satisfactions")
}

/// Pantalla TV configurable. Cada clínica puede tener N pantallas
/// con modos OPERATIONAL (halos), MARKETING (carousel + testimonios)
/// o HYBRID (split). publicSlug es la URL pública que se carga en la TV.
model TVDisplay {
  id         String   @id @default(cuid())
  clinicId   String
  name       String   @db.VarChar(120)
  mode       String   @db.VarChar(20) /// OPERATIONAL | MARKETING | HYBRID
  config     Json /// promociones, testimonios, branding, etc.
  publicSlug String   @unique @db.VarChar(80)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, active])
  @@map("tv_displays")
}

// ═══════════════════════════════════════════════════════════════════
// Bug Audit — registros de auditoría de seguridad/perf/calidad.
// Tabla global (no multi-tenant), solo SUPER_ADMIN puede invocarla
// desde /dashboard/admin/bug-audit. RLS habilitada en SQL para
// bloquear acceso directo a la DB sin service role.
// ═══════════════════════════════════════════════════════════════════

model BugAuditRun {
  id          String   @id
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  /// clinicId del SUPER_ADMIN que disparó el run (nullable para runs programáticos).
  clinicId    String?
  /// userId del actor (FK soft, no enforced).
  userId      String?
  runAt       DateTime @default(now()) @db.Timestamptz(6)
  triggeredBy String
  status      String   @default("completed")
  durationMs  Int      @default(0)
  summary     Json
  items       Json     @default("[]")

  @@index([runAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([clinicId])
  @@map("bug_audit_runs")
}

model BugAuditDismissed {
  id          String   @id
  fingerprint String   @unique
  reason      String?
  dismissedBy String
  dismissedAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("bug_audit_dismissed")
}

// ═══════════════════════════════════════════════════════════════════
// Marketplace de módulos (Sprint 1)
//
// Modelo de monetización por módulo: cada clínica activa N módulos a
// $229–$399/mes. Trial de 14 días desbloquea TODO; post-trial sólo los
// módulos con ClinicModule.status='active' y currentPeriodEnd futuro.
// La tabla Order es de marketplace (compras de módulos), distinta de
// SubscriptionInvoice (billing anual de la clínica completa).
// ═══════════════════════════════════════════════════════════════════

/// Catálogo de módulos disponibles para venta. Tabla GLOBAL (sin
/// clinicId). Seed canónico en prisma/seed.ts. iconKey es el nombre
/// del icono de lucide-react que usa la UI del marketplace.
model Module {
  id              String   @id @default(cuid())
  key             String   @unique
  name            String
  category        String
  description     String   @db.Text
  iconKey         String   @map("icon_key")
  iconBg          String   @map("icon_bg")
  iconColor       String   @map("icon_color")
  features        String[]
  priceMxnMonthly Int      @map("price_mxn_monthly")
  isCore          Boolean  @default(false) @map("is_core")
  dependsOn       String[] @map("depends_on")
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")

  clinicModules ClinicModule[]

  @@map("modules")
}

/// Relación clínica-módulo activo. Un Stripe Subscription por módulo
/// (decisión de Sprint 1: 1:1 con stripeSubscriptionId). Estados:
///   active — pagado y vigente
///   trial — periodo de prueba post-compra individual (futuro, ignorar)
///   paused — pago falló, pendiente de retry
///   cancelled — cancelado por el usuario o admin
model ClinicModule {
  id                   String    @id @default(cuid())
  clinicId             String    @map("clinic_id")
  moduleId             String    @map("module_id")
  status               String
  billingCycle         String    @map("billing_cycle")
  activatedAt          DateTime  @default(now()) @map("activated_at")
  currentPeriodStart   DateTime  @map("current_period_start")
  currentPeriodEnd     DateTime  @map("current_period_end")
  cancelledAt          DateTime? @map("cancelled_at")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  paypalSubscriptionId String?   @unique @map("paypal_subscription_id")
  paymentMethod        String    @map("payment_method")
  pricePaidMxn         Int       @map("price_paid_mxn")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id])

  @@unique([clinicId, moduleId])
  @@index([clinicId])
  @@index([currentPeriodEnd])
  @@map("clinic_modules")
}

/// Log de uso por módulo — alimenta sugerencias post-trial.
model ModuleUsageLog {
  id        String   @id @default(cuid())
  clinicId  String   @map("clinic_id")
  moduleKey String   @map("module_key")
  action    String
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, moduleKey])
  @@index([createdAt])
  @@map("module_usage_logs")
}

/// Orden de checkout. Una orden puede contener N módulos. Snapshot de
/// montos al momento de la compra (no se recalcula). cfdiId/cfdiUuid se
/// llenan tras emisión vía FacturAPI en el webhook del pago.
model Order {
  id                  String    @id @default(cuid())
  clinicId            String    @map("clinic_id")
  status              String
  paymentMethod       String    @map("payment_method")
  billingCycle        String    @map("billing_cycle")
  moduleIds           String[]  @map("module_ids")
  subtotalMxn         Int       @map("subtotal_mxn")
  annualBonusMxn      Int       @default(0) @map("annual_bonus_mxn")
  volumeDiscountPct   Int       @default(0) @map("volume_discount_pct")
  volumeDiscountMxn   Int       @default(0) @map("volume_discount_mxn")
  taxMxn              Int       @map("tax_mxn")
  totalMxn            Int       @map("total_mxn")
  speiReference       String?   @unique @map("spei_reference")
  stripePaymentIntent String?   @map("stripe_payment_intent")
  paypalOrderId       String?   @map("paypal_order_id")
  cfdiId              String?   @map("cfdi_id")
  cfdiUuid            String?   @map("cfdi_uuid")
  createdAt           DateTime  @default(now()) @map("created_at")
  paidAt              DateTime? @map("paid_at")

  clinic Clinic @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
  @@index([status])
  @@map("orders")
}

/// Carrito persistente — opción B del brief. Una clínica = un carrito.
/// moduleIds es array de Module.id; el cliente decide billingCycle al
/// hacer checkout (no se persiste aquí).
model Cart {
  clinicId  String   @id @map("clinic_id")
  moduleIds String[] @map("module_ids")
  updatedAt DateTime @updatedAt @map("updated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("carts")
}

