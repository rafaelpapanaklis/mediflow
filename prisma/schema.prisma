model PatientFile {
  id          String       @id @default(cuid())
  patientId   String
  clinicId    String
  uploadedBy  String?
  name        String
  url         String
  size        Int?
  mimeType    String?
  category    FileCategory @default(OTHER)
  toothNumber Int?
  notes       String?
  takenAt     DateTime?
  createdAt   DateTime     @default(now())

  // Notas clínicas del doctor sobre este archivo (independientes de las notas de upload y del análisis IA)
  doctorNotes          String?   @db.Text
  doctorNotesUpdatedAt DateTime?

  // Anotaciones del visor (regla, ángulo, lápiz). Array de
  // { id, type: "ruler"|"angle"|"freehand", points: [{x,y}], label?, color? }
  // Las coordenadas son relativas (0..1) al rect natural de la imagen para
  // que el dibujo sea estable a cualquier zoom/tamaño de visor.
  annotations Json?

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  xrayAnalysis XrayAnalysis?

  // Endodontics module — radiografías referenciadas como conductometría /
  // controles / intraoperatorio. SPEC §1.4 reutiliza PatientFile en lugar
  // de crear un modelo Radiography separado.
  conductometryRootCanals RootCanal[]          @relation("ConductometryFile")
  followUpsAsControl      EndodonticFollowUp[] @relation("FollowUpFile")
  apicalSurgeries         ApicalSurgery[]      @relation("ApicalSurgeryFile")

  // Periodontics module — fotos intraoperatorias y consentimientos firmados
  // de cirugías. SPEC §1.16 reutiliza PatientFile (no se crea modelo
  // Radiography). Spec §4.3.
  surgeryIntraOpFor PeriodontalSurgery[] @relation("SurgeryIntraOpFile")
  surgeryConsentFor PeriodontalSurgery[] @relation("SurgeryConsentFile")

  // Orthodontics module v2 — PatientFile YA NO se usa para ortho.
  // El nuevo módulo guarda URLs directas en Photo.url + OrthoDocument.url
  // sin pasar por la tabla PatientFile (ver docs/ortho-redesign-v2/SPEC.md §1.1).

  // Implants module — radiografías peri-implantarias, foto intraoperatoria
  // de la cirugía, foto del paciente para el carnet, PDF del carnet,
  // consentimientos firmados. Ver SPEC §8.5.
  implantSurgicalIntraoperative ImplantSurgicalRecord[] @relation("ImplantSurgicalIntraoperativePhoto")
  implantFollowUpsRadiograph    ImplantFollowUp[]       @relation("ImplantFollowUpRadiograph")
  implantPassportsPhoto         ImplantPassport[]       @relation("ImplantPassportPhoto")
  implantPassportsPdf           ImplantPassport[]       @relation("ImplantPassportPdf")
  implantConsentsSigned         ImplantConsent[]        @relation("ImplantConsentSigned")

  @@index([clinicId, patientId, createdAt(sort: Desc)])
  @@index([patientId, category])
  @@map("patient_files")
}

// ── AI analysis of radiographs (cached per file) ──────────────────────
model XrayAnalysis {
  id        String      @id @default(cuid())
  fileId    String      @unique
  file      PatientFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  clinicId  String
  clinic    Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId String
  patient   Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Modo de análisis. GENERAL es el default histórico (free-form findings).
  // PERIODONTAL_BONE_LOSS y PERIIMPLANT_BONE_LOSS son flujos dedicados con
  // mediciones por sitio/implante. A2 cross-módulos.
  // Un fileId tiene UN análisis: si el doctor cambia de modo y re-analiza,
  // el nuevo modo sobreescribe al anterior (upsert por fileId).
  mode XrayAnalysisMode @default(GENERAL)

  // Contenido del análisis
  summary         String @db.Text
  findings        Json // array con { id, title, description, tooth, severity, confidence }
  recommendations Json // string o array — el endpoint lo persiste tal cual

  // Mediciones específicas por modo (null para GENERAL):
  //   PERIODONTAL_BONE_LOSS: { sites: [{ toothFdi, position, lossMm, type: "horizontal"|"vertical", bopPresent }, ...] }
  //   PERIIMPLANT_BONE_LOSS: { implantFdi, mesialMm, distalMm, baselineDate?, comparisonNote? }
  measurements Json?

  // Top-level derivados (para queries/filtros sin parsear JSON)
  severity   String // max de findings: alta | media | baja | informativo
  confidence Float // avg de findings, 0-100

  // Metadata
  tokensUsed Int      @default(0)
  modelUsed  String   @default("claude-sonnet-4-6")
  createdAt  DateTime @default(now())
  createdBy  String? // userId del doctor que lo generó

  @@index([clinicId])
  @@index([patientId])
  @@index([severity])
  @@index([mode])
  @@map("xray_analyses")
}

enum XrayAnalysisMode {
  GENERAL
  PERIODONTAL_BONE_LOSS
  PERIIMPLANT_BONE_LOSS
}

enum FileCategory {
  XRAY_PERIAPICAL
  XRAY_PANORAMIC
  XRAY_BITEWING
  XRAY_OCCLUSAL
  XRAY_CBCT
  PHOTO_FRONTAL
  PHOTO_LATERAL
  PHOTO_OCCLUSAL_UPPER
  PHOTO_OCCLUSAL_LOWER
  PHOTO_INTRAORAL
  PHOTO_PATIENT
  CONSENT_FORM
  // Orthodontics module — set fotográfico T0/T1/T2 + controles + cefalo + STL.
  // SPEC §1.3 + §1.20: reuso de PatientFile con FileCategory tipado.
  ORTHO_PHOTO_T0
  ORTHO_PHOTO_T1
  ORTHO_PHOTO_T2
  ORTHO_PHOTO_CONTROL
  CEPH_ANALYSIS_PDF
  SCAN_STL
  OTHER
}

