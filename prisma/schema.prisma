generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clinic {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  specialty       String // @deprecated — usar category en su lugar
  category        ClinicCategory @default(OTHER)
  country         String         @default("MX")
  state           String? // MX state (e.g., "Ciudad de México", "Jalisco")
  city            String?
  address         String?
  phone           String?
  clinicSize      String? // "1" | "2-5" | "6-15" | "16+" — captured at signup
  email           String?
  logoUrl         String?
  taxId           String?
  isPublic        Boolean        @default(false)
  description     String?
  plan            Plan           @default(PRO)
  // Trial — 14 días desde creación. trialStartedAt agregado en Sprint 1
  // marketplace; antes derivábamos de createdAt. trialEndsAt pasa a NOT NULL
  // tras backfill de la migración marketplace_foundation.
  trialStartedAt  DateTime       @default(now()) @map("trial_started_at")
  trialEndsAt     DateTime
  trialNotified7d Boolean        @default(false) @map("trial_notified_7d")
  trialNotified3d Boolean        @default(false) @map("trial_notified_3d")
  trialNotified1d Boolean        @default(false) @map("trial_notified_1d")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // WhatsApp (legacy Meta Cloud API)
  waPhoneNumberId  String?
  waAccessToken    String?
  waConnected      Boolean @default(false)
  waReminderActive Boolean @default(true)
  waReminder24h    Boolean @default(true)
  waReminder1h     Boolean @default(false)
  waReminderMsg    String?

  // Inbox unificado — Twilio Conversations + Postmark Inbound
  twilioAccountSid     String? // SID de la cuenta Twilio (admin la conecta en /settings/integrations)
  twilioAuthToken      String? // token (encrypted-at-rest en producción)
  twilioWhatsappNumber String? // E.164: "+5215512345678"
  postmarkInboundEmail String? // ej: clinica-abc@inbox.mediflow.app — único por clínica

  // Google Calendar — clinic-level shared calendar
  googleCalendarToken    String? // access token of the admin who connected
  googleRefreshToken     String? // refresh token
  googleCalendarEmail    String? // google account email
  googleCalendarEnabled  Boolean @default(false)
  googleClinicCalendarId String? // ID of the "clinic" calendar in Google

  // CFDI / Facturación SAT
  facturApiOrgId   String?
  rfcEmisor        String?
  regimenFiscal    String?
  cpEmisor         String?
  facturApiEnabled Boolean @default(false)

  // Identificación NOM-024 — CLUES Sector Salud (Compliance Fase A)
  clues String? @db.VarChar(11)

  // Subscription / Billing
  subscriptionStatus     String? // active, trialing, past_due, cancelled
  subscriptionId         String? // legacy — Stripe/MP subscription ID
  nextBillingDate        DateTime?
  monthlyPrice           Float?    @default(0)
  // Stripe subscription billing
  stripeCustomerId       String? // Stripe Customer ID for the clinic owner
  stripeSubscriptionId   String? // Stripe Subscription ID (recurring)
  stripePaymentMethodId  String? // default payment method
  // PayPal
  paypalSubscriptionId   String? // PayPal subscription ID (recurring)
  paypalEmail            String? // PayPal email for manual payments
  // Payment preferences
  preferredPaymentMethod String? // stripe, paypal, transfer, oxxo
  // Signup payment method capture (UI-only until Stripe wired)
  paymentMethodCollected Boolean   @default(false)
  paymentMethodType      String? // "card" | "paypal" | "transfer"
  paymentMethodLast4     String? // last 4 digits (card only, for display)
  // Cancellation request (user-initiated from settings)
  cancelRequested        Boolean   @default(false)
  cancelRequestedAt      DateTime?
  recallMonths           Int       @default(6) // months before annual reminder
  recallActive           Boolean   @default(false)
  googlePlaceId          String? // Google Maps Place ID for fetching reviews

  // Landing page
  landingActive       Boolean  @default(false)
  landingThemeColor   String?  @default("#2563eb")
  landingCoverUrl     String?
  landingGallery      String[] @default([])
  landingTestimonials Json?
  landingFaqs         Json?
  landingServices     Json?
  landingHours        Json?
  landingWhatsapp     String?
  landingInstagram    String?
  landingFacebook     String?
  landingTiktok       String?
  landingMapEmbed     String?
  landingTagline      String?

  // AI Assistant usage tracking
  aiTokensUsed  Int      @default(0)
  aiTokensLimit Int      @default(50000)
  aiLastResetAt DateTime @default(now())

  // Telemedicine
  teleEnabled       Boolean @default(false)
  teleCommissionPct Float   @default(15)
  dailyApiKey       String?

  // Agenda config (Fase 4)
  defaultSlotMinutes Int    @default(15)
  agendaDayStart     Int    @default(8)
  agendaDayEnd       Int    @default(20)
  timezone           String @default("America/Mexico_City")

  // ── Mi Clínica Visual — vista pública en vivo ──
  // Cada clínica puede compartir su modo "En Vivo" para mostrar en TV de
  // sala de espera. URL pública: /live/<liveModeSlug>. Si liveModePassword
  // está set, los visitantes deben ingresar el password una vez (cookie
  // unlock 12h). showPatientNames=false → solo iniciales en halos (HIPAA).
  liveModeSlug             String? @unique
  liveModePassword         String? // bcrypt hash; null = sin protección
  liveModeEnabled          Boolean @default(false)
  liveModeShowPatientNames Boolean @default(false)

  users                User[]
  patients             Patient[]
  appointments         Appointment[]
  records              MedicalRecord[]
  invoices             Invoice[]
  schedules            ClinicSchedule[]
  inventory            InventoryItem[]
  reminders            WhatsAppReminder[]
  cfdis                CfdiRecord[]
  treatments           TreatmentPlan[]
  paymentPlans         PaymentPlan[]
  consentForms         ConsentForm[]
  periodontalRecords   PeriodontalRecord[]
  subscriptionInvoices SubscriptionInvoice[]
  files                PatientFile[]
  auditLogs            AuditLog[]
  beforeAfterPhotos    BeforeAfterPhoto[]
  servicePackages      ServicePackage[]
  formulaRecords       FormulaRecord[]
  bodyMapAnnotations   BodyMapAnnotation[]
  walkInQueue          WalkInQueue[]
  resourceBookings     ResourceBooking[]
  procedureCatalog     ProcedureCatalog[]
  xrayAnalyses         XrayAnalysis[]
  adminNotes           AdminClinicNote[]
  prescriptions        Prescription[]
  resources            Resource[]
  waitlistEntries      WaitlistEntry[]
  inboxThreads         InboxThread[]
  remindersList        Reminder[]
  clinicLayout         ClinicLayout?
  // Analytics (Push 1)
  weeklyInsights       WeeklyInsight[]
  tvDisplays           TVDisplay[]
  // Compliance Fase C
  referrals            Referral[]
  // Marketplace de módulos (Sprint 1) — 1:N con módulos comprados,
  // logs de uso, órdenes de checkout y 1:1 con carrito persistente.
  clinicModules        ClinicModule[]
  moduleUsageLogs      ModuleUsageLog[]
  orders               Order[]
  cart                 Cart?

  // Endodontics module — see docs/marketplace/research/endodoncia/SPEC.md §4
  endodonticDiagnoses  EndodonticDiagnosis[]
  vitalityTests        VitalityTest[]
  endodonticTreatments EndodonticTreatment[]

  // Periodontics module — see docs/marketplace/research/periodoncia/SPEC.md §4
  periodontalClassifications PeriodontalClassification[]
  gingivalRecessions         GingivalRecession[]
  periodontalPlans           PeriodontalTreatmentPlan[]
  srpSessions                SRPSession[]
  periodontalReevaluations   PeriodontalReevaluation[]
  periodontalRiskAssessments PeriodontalRiskAssessment[]
  periodontalSurgeries       PeriodontalSurgery[]
  periImplantAssessments     PeriImplantAssessment[]

  // Orthodontics module v2 — see docs/ortho-redesign-v2/SPEC.md
  orthoCases               OrthoCase[]
  orthoTemplates           OrthoTemplate[]
  orthoNoteTemplates       NoteTemplate[]
  orthoIndicationTemplates IndicationTemplate[]
  orthoApplianceTypes      ApplianceType[]
  patientFlowEntries       PatientFlow[]

  // Implants module — see docs/marketplace/research/implantologia/SPEC.md §4
  implants             Implant[]
  implantCatalogModels ImplantCatalogModel[]

  // Clinical-shared cross-cutting features
  clinicalPhotos             ClinicalPhoto[]
  clinicalEvolutionTemplates ClinicalEvolutionTemplate[]
  referralLetters            ReferralLetter[]
  doctorContacts             DoctorContact[]
  labOrders                  LabOrder[]
  labPartners                LabPartner[]
  clinicalReminders          ClinicalReminder[]
  patientShareLinks          PatientShareLink[]
  treatmentLinks             TreatmentLink[]

  @@map("clinics")
}

enum ClinicCategory {
  DENTAL
  MEDICINE
  NUTRITION
  PSYCHOLOGY
  DERMATOLOGY
  AESTHETIC_MEDICINE
  HAIR_RESTORATION
  BEAUTY_CENTER
  BROW_LASH
  MASSAGE
  LASER_HAIR_REMOVAL
  HAIR_SALON
  ALTERNATIVE_MEDICINE
  NAIL_SALON
  SPA
  PHYSIOTHERAPY
  PODIATRY
  OTHER
}

enum Plan {
  BASIC
  PRO
  CLINIC
}

model User {
  id         String  @id @default(cuid())
  supabaseId String
  clinicId   String
  email      String
  firstName  String
  lastName   String
  role       Role    @default(DOCTOR)
  specialty  String?
  avatarUrl  String?
  phone      String?
  isActive   Boolean @default(true)

  // Identificación NOM-024 (Compliance Fase A) — médicos
  cedulaProfesional  String? @db.VarChar(15)
  especialidad       String? @db.VarChar(100)
  cedulaEspecialidad String? @db.VarChar(15)

  // Firma electrónica avanzada FIEL/SAT (Compliance Fase C)
  signatureCert     DoctorSignatureCert?
  referralsAuthored Referral[]
  color             String               @default("#3b82f6")
  agendaActive      Boolean              @default(true)
  lastLogin         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  // Google Calendar
  googleCalendarToken   String?
  googleRefreshToken    String?
  googleCalendarEmail   String?
  googleCalendarEnabled Boolean  @default(false)
  services              String[] @default([])

  // Stripe Connect (telemedicine payments)
  stripeAccountId  String?
  stripeOnboarded  Boolean @default(false)
  teleconsultPrice Float?

  // Override granular del set default del role. Array de keys de permiso
  // ("agenda.view", "patients.edit", ...). Si está vacío se aplica el
  // default del role; si tiene keys, esas REEMPLAZAN al default. Gestión
  // por SUPER_ADMIN desde /dashboard/team. Ver src/lib/auth/permissions.ts.
  permissionsOverride String[] @default([])

  clinic             Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments       Appointment[]
  records            MedicalRecord[]
  primaryPatients    Patient[]           @relation("PrimaryDoctor")
  treatments         TreatmentPlan[]
  periodontalRecords PeriodontalRecord[]
  auditLogs          AuditLog[]
  adminNotesAuthored AdminClinicNote[]
  prescriptions      Prescription[]
  apptsOverriddenBy  Appointment[]       @relation("ApptOverriddenBy")
  waitlistCreated    WaitlistEntry[]     @relation("WaitlistCreatedBy")
  waitlistPreferred  WaitlistEntry[]     @relation("WaitlistPreferredDoctor")
  inboxAssigned      InboxThread[]       @relation("InboxAssignee")
  inboxSent          InboxMessage[]
  remindersCreated   Reminder[]          @relation("ReminderCreator")
  remindersAssigned  Reminder[]          @relation("ReminderAssignee")

  // Endodontics module — see docs/marketplace/research/endodoncia/SPEC.md §4
  endoDiagnosisDoctor EndodonticDiagnosis[] @relation("EndoDiagnosisDoctor")
  vitalityDoctor      VitalityTest[]        @relation("VitalityDoctor")
  endoTreatmentDoctor EndodonticTreatment[] @relation("EndoTreatmentDoctor")

  // Periodontics module — see docs/marketplace/research/periodoncia/SPEC.md §4
  periodontalClassifications        PeriodontalClassification[]
  recordedRecessions                GingivalRecession[]
  srpSessionsAsDoctor               SRPSession[]                @relation("SrpDoctor")
  reevaluationsAsEvaluator          PeriodontalReevaluation[]
  riskAssessmentsAsEvaluator        PeriodontalRiskAssessment[]
  surgeriesAsDoctor                 PeriodontalSurgery[]        @relation("PerioSurgeryDoctor")
  periImplantAssessmentsAsEvaluator PeriImplantAssessment[]

  // Orthodontics module v2 — see docs/ortho-redesign-v2/SPEC.md
  orthoCasesAsDoctor    OrthoCase[]   @relation("OrthoCasePrimaryDoctor")
  patientFlowsTriggered PatientFlow[] @relation("PatientFlowTriggeredBy")

  // Implants module — see docs/marketplace/research/implantologia/SPEC.md §4
  implantsPlaced          Implant[]        @relation("ImplantPlacedBy")
  implantConsentsAsDoctor ImplantConsent[] @relation("ImplantConsentDoctor")

  // Clinical-shared cross-cutting features
  clinicalPhotosCaptured     ClinicalPhoto[]             @relation("ClinicalPhotoCapturedBy")
  evolutionTemplatesCreated  ClinicalEvolutionTemplate[] @relation("EvolutionTemplateCreatedBy")
  referralLettersAuthored    ReferralLetter[]            @relation("ReferralLetterAuthor")
  labOrdersAuthored          LabOrder[]                  @relation("LabOrderAuthor")
  clinicalRemindersCreated   ClinicalReminder[]          @relation("ClinicalReminderCreator")
  patientShareLinksGenerated PatientShareLink[]          @relation("PatientShareLinkCreator")
  treatmentLinksAuthored     TreatmentLink[]             @relation("TreatmentLinkAuthor")

  @@unique([supabaseId, clinicId])
  @@index([supabaseId])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  RECEPTIONIST
  READONLY
}

model Patient {
  id                 String        @id @default(cuid())
  clinicId           String
  patientNumber      String
  firstName          String
  lastName           String
  email              String?
  phone              String?
  dob                DateTime?
  gender             Gender        @default(OTHER)
  bloodType          String?
  address            String?
  insuranceProvider  String?
  insurancePolicy    String?
  allergies          String[]      @default([])
  chronicConditions  String[]      @default([])
  currentMedications String[]      @default([])
  tags               String[]      @default([])
  notes              String?
  status             PatientStatus @default(ACTIVE)
  isChild            Boolean       @default(false) // true = dentición temporal
  primaryDoctorId    String?

  // Portal del paciente
  portalToken       String?   @unique
  portalTokenExpiry DateTime?

  // Identificación NOM-024 (Compliance Fase A)
  curp       String?    @db.VarChar(18)
  curpStatus CurpStatus @default(PENDING)
  passportNo String?    @db.VarChar(20)

  // NOM-004 antecedentes (Compliance Fase A)
  familyHistory                  String? @db.Text
  personalNonPathologicalHistory String? @db.Text

  // Datos fiscales para CFDI
  rfcPaciente      String?
  regimenFiscalPac String?
  cpPaciente       String?
  razonSocialPac   String?

  // Extended fields for multi-category
  skinPhototype     String?
  hairType          String?
  nailCondition     String?
  painAreas         Json?
  mobilityNotes     String?
  diabeticRisk      String?
  doshaType         String?
  preferredPressure Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ARCO cancellation (LFPDPPP) — soft delete + anonimización del PII.
  // NOM-024 obliga a retener historia clínica 5 años, por eso aquí no se
  // hace DELETE: deletedAt oculta al paciente de listas/agenda y
  // anonymizedAt marca cuándo se reemplazó el PII por placeholders.
  deletedAt    DateTime?
  anonymizedAt DateTime?

  clinic              Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  primaryDoctor       User?                @relation("PrimaryDoctor", fields: [primaryDoctorId], references: [id])
  appointments        Appointment[]
  records             MedicalRecord[]
  invoices            Invoice[]
  files               PatientFile[]
  treatments          TreatmentPlan[]
  paymentPlans        PaymentPlan[]
  consentForms        ConsentForm[]
  periodontalRecords  PeriodontalRecord[]
  beforeAfterPhotos   BeforeAfterPhoto[]
  formulaRecords      FormulaRecord[]
  bodyMapAnnotations  BodyMapAnnotation[]
  packageRedemptions  PackageRedemption[]
  xrayAnalyses        XrayAnalysis[]
  prescriptions       Prescription[]
  waitlistEntries     WaitlistEntry[]
  odontogramEntries   OdontogramEntry[]
  odontogramSnapshots OdontogramSnapshot[]
  inboxThreads        InboxThread[]
  patientReminders    Reminder[]
  referrals           Referral[]

  // Pediatrics module — see docs/marketplace/research/odontopediatria/SPEC.md §5
  pediatricRecord      PediatricRecord?
  guardians            Guardian[]
  behaviorAssessments  BehaviorAssessment[]
  cariesAssessments    CariesRiskAssessment[]
  oralHabits           OralHabit[]
  eruptionRecords      EruptionRecord[]
  spaceMaintainers     SpaceMaintainer[]
  sealants             Sealant[]
  fluorideApplications FluorideApplication[]
  endoTreatments       PediatricEndodonticTreatment[]
  pediatricConsents    PediatricConsent[]

  // Endodontics module — see docs/marketplace/research/endodoncia/SPEC.md §4
  endodonticDiagnoses  EndodonticDiagnosis[]
  vitalityTests        VitalityTest[]
  endodonticTreatments EndodonticTreatment[]

  // Periodontics module — see docs/marketplace/research/periodoncia/SPEC.md §4
  periodontalClassifications PeriodontalClassification[]
  gingivalRecessions         GingivalRecession[]
  periodontalPlans           PeriodontalTreatmentPlan[]
  srpSessions                SRPSession[]
  periodontalReevaluations   PeriodontalReevaluation[]
  periodontalRiskAssessments PeriodontalRiskAssessment[]
  periodontalSurgeries       PeriodontalSurgery[]
  periImplantAssessments     PeriImplantAssessment[]

  // Orthodontics module v2 — see docs/ortho-redesign-v2/SPEC.md
  orthoCase          OrthoCase?
  patientFlowEntries PatientFlow[]

  // Implants module — see docs/marketplace/research/implantologia/SPEC.md §4
  implants        Implant[]
  implantConsents ImplantConsent[]

  // Clinical-shared cross-cutting features
  clinicalPhotos    ClinicalPhoto[]
  referralLetters   ReferralLetter[]
  labOrders         LabOrder[]
  clinicalReminders ClinicalReminder[]
  patientShareLinks PatientShareLink[]

  @@unique([clinicId, patientNumber])
  @@index([clinicId, status])
  @@index([clinicId, createdAt(sort: Desc)])
  @@index([primaryDoctorId])
  @@map("patients")
}

/// Estado por superficie del odontograma (32 dientes adultos / 5 superficies).
/// `surface` null = estado aplicado al diente completo (corona, ausente, etc).
model OdontogramEntry {
  id          String   @id @default(cuid())
  patientId   String
  toothNumber Int // FDI numbering (11-18, 21-28, 31-38, 41-48, etc.)
  surface     String? // M | D | V | L | O | null (full tooth)
  state       String // SANO | CARIES | RESINA | CORONA | ENDODONCIA | IMPLANTE | AUSENTE | EXTRACCION
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, toothNumber, surface])
  @@index([patientId])
  @@map("odontogram_entries")
}

/// Snapshot inmutable del odontograma al cerrar una consulta. Permite
/// reconstruir el estado dental en cualquier punto en el tiempo y diff'ear
/// contra el snapshot anterior para detectar tratamientos hechos.
/// `entries` es JSON: [{ toothNumber, surface, state, notes }, ...].
model OdontogramSnapshot {
  id            String   @id @default(cuid())
  patientId     String
  appointmentId String   @unique
  snapshotAt    DateTime @default(now())
  entries       Json

  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([patientId, snapshotAt])
  @@map("odontogram_snapshots")
}

enum Gender {
  M
  F
  OTHER
}

enum CurpStatus {
  COMPLETE
  PENDING
  FOREIGN
}

/// Certificado FIEL/e.firma del SAT del médico — para firma electrónica
/// avanzada de recetas/notas. Multi-tenant via User.clinicId.
model DoctorSignatureCert {
  id            String   @id @default(cuid())
  userId        String   @unique
  cerFileUrl    String   @db.Text
  keyFileUrl    String   @db.Text
  keyEncIv      String   @db.VarChar(48)
  keyEncAuthTag String   @db.VarChar(48)
  cerSerial     String   @db.VarChar(60)
  cerIssuer     String   @db.VarChar(200)
  validFrom     DateTime @db.Timestamptz(6)
  validUntil    DateTime @db.Timestamptz(6)
  rfc           String   @db.VarChar(13)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([rfc])
  @@map("doctor_signature_certs")
}

/// Documento firmado electrónicamente — receta, nota clínica o consent.
/// docId es FK polimórfica (no enforced) al documento original.
/// clinicId siempre presente para scope multi-tenant.
model SignedDocument {
  id           String        @id @default(cuid())
  clinicId     String
  docType      SignedDocType
  docId        String
  signerUserId String
  sha256       String        @db.VarChar(64)
  signature    String        @db.Text
  tsaTimestamp String?       @db.Text
  signedAt     DateTime      @default(now()) @db.Timestamptz(6)

  @@index([clinicId, docType])
  @@index([docId])
  @@map("signed_documents")
}

enum SignedDocType {
  PRESCRIPTION
  MEDICAL_RECORD
  CONSENT
  OTHER
}

/// NOM-024 — referencia y contrarreferencia entre clínicas.
/// La referencia (OUTGOING) la emite la clínica origen; la
/// contrarreferencia (INCOMING) llega como respuesta cuando la clínica
/// destino devuelve al paciente con notas.
///
/// Multi-tenant: clinicId es la clínica que crea/posee el registro
/// (origen para OUTGOING, receptor para INCOMING).
model Referral {
  id                String         @id @default(cuid())
  clinicId          String
  patientId         String
  fromDoctorId      String
  toClinicName      String         @db.VarChar(200)
  toClinicClues     String?        @db.VarChar(11)
  toDoctorName      String?        @db.VarChar(200)
  toSpecialty       String?        @db.VarChar(100)
  reason            String         @db.Text
  clinicalSummary   String         @db.Text
  relevantDiagnoses Json?
  type              ReferralType
  status            ReferralStatus @default(SENT)
  sentAt            DateTime       @default(now()) @db.Timestamptz(6)
  respondedAt       DateTime?      @db.Timestamptz(6)
  response          String?        @db.Text

  clinic     Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fromDoctor User    @relation(fields: [fromDoctorId], references: [id])

  @@index([clinicId, status])
  @@index([patientId])
  @@map("referrals")
}

enum ReferralType {
  OUTGOING
  INCOMING
}

enum ReferralStatus {
  SENT
  ACCEPTED
  REJECTED
  RESPONDED
  CANCELLED
}

/// Solicitud ARCO (Acceso, Rectificación, Cancelación, Oposición) bajo
/// LFPDPPP. clinicId puede ser null si la solicitud llega del aviso
/// público (sin paciente identificado). Si patientId viene, validamos
/// que pertenezca a una clínica y heredamos clinicId.
model ArcoRequest {
  id            String     @id @default(cuid())
  clinicId      String?
  patientId     String?
  type          ArcoType
  reason        String     @db.Text
  email         String     @db.VarChar(200)
  status        ArcoStatus @default(PENDING)
  resolvedAt    DateTime?  @db.Timestamptz(6)
  resolvedNotes String?    @db.Text
  createdAt     DateTime   @default(now()) @db.Timestamptz(6)

  @@index([clinicId, status])
  @@index([email])
  @@map("arco_requests")
}

enum ArcoType {
  ACCESS
  RECTIFICATION
  CANCELLATION
  OPPOSITION
}

enum ArcoStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Appointment {
  id        String   @id @default(cuid())
  clinicId  String
  patientId String
  doctorId  String
  type      String
  startsAt  DateTime @db.Timestamptz(6)
  endsAt    DateTime @db.Timestamptz(6)

  resourceId String?

  source             AppointmentSource @default(STAFF)
  requiresValidation Boolean           @default(false)

  overrideReason String?   @db.VarChar(500)
  overriddenBy   String?
  overriddenAt   DateTime? @db.Timestamptz(6)

  checkedInAt DateTime? @db.Timestamptz(6)
  startedAt   DateTime? @db.Timestamptz(6)
  completedAt DateTime? @db.Timestamptz(6)

  room                  String?
  status                AppointmentStatus @default(PENDING)
  notes                 String?
  reminderSent          Boolean           @default(false)
  confirmedAt           DateTime?
  cancelledAt           DateTime?
  cancelReason          String?
  googleCalendarEventId String?
  price                 Float?
  stripePaymentIntentId String?
  isPaid                Boolean           @default(false)

  // Telemedicine
  mode             AppointmentMode @default(IN_PERSON)
  teleRoomId       String?
  teleRoomUrl      String?
  teleDoctorToken  String?
  telePatientToken String?
  teleRecordingUrl String?
  paymentStatus    String?
  paymentAmount    Float?
  stripePaymentId  String?
  stripeSessionId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic               Clinic                         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient              Patient                        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor               User                           @relation(fields: [doctorId], references: [id])
  resource             Resource?                      @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  overriddenByUser     User?                          @relation("ApptOverriddenBy", fields: [overriddenBy], references: [id], onDelete: SetNull)
  invoice              Invoice?
  odontogramSnapshot   OdontogramSnapshot?
  // Orthodontics v2 — link bidi con TreatmentCard (SPEC §2)
  treatmentCard        TreatmentCard?
  reminders            WhatsAppReminder[]
  // Analytics relations (Push 1)
  timeline             AppointmentTimeline?
  noShowPrediction     NoShowPrediction?
  satisfaction         PatientSatisfaction?
  // Pediatrics module — see docs/marketplace/research/odontopediatria/SPEC.md §5
  behaviorAssessments  BehaviorAssessment[]
  fluorideApplications FluorideApplication[]
  spaceMaintainers     SpaceMaintainer[]
  endoTreatments       PediatricEndodonticTreatment[]

  @@index([clinicId, startsAt, endsAt, status])
  @@index([doctorId, startsAt])
  @@index([resourceId, startsAt])
  @@index([clinicId, requiresValidation])
  @@map("appointments")
}

