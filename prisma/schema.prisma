generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clinic {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  specialty   String
  country     String    @default("MX")
  city        String?
  address     String?
  phone       String?
  email       String?
  logoUrl     String?
  taxId       String?
  isPublic    Boolean   @default(false)
  description String?
  plan        Plan      @default(PRO)
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // WhatsApp
  waPhoneNumberId  String?
  waAccessToken    String?
  waConnected      Boolean @default(false)
  waReminderActive Boolean @default(true)
  waReminder24h    Boolean @default(true)
  waReminder1h     Boolean @default(false)
  waReminderMsg    String?

  // Google Calendar — clinic-level shared calendar
  googleCalendarToken     String?   // access token of the admin who connected
  googleRefreshToken      String?   // refresh token
  googleCalendarEmail     String?   // google account email
  googleCalendarEnabled   Boolean   @default(false)
  googleClinicCalendarId  String?   // ID of the "clinic" calendar in Google

  // CFDI / Facturación SAT
  facturApiOrgId    String?
  rfcEmisor         String?
  regimenFiscal     String?
  cpEmisor          String?
  facturApiEnabled  Boolean @default(false)

  // AI Assistant usage tracking
  aiTokensUsed  Int      @default(0)
  aiTokensLimit Int      @default(50000)
  aiLastResetAt DateTime @default(now())

  users        User[]
  patients     Patient[]
  appointments Appointment[]
  records      MedicalRecord[]
  invoices     Invoice[]
  schedules    ClinicSchedule[]
  inventory    InventoryItem[]
  reminders    WhatsAppReminder[]
  cfdis        CfdiRecord[]
  treatments   TreatmentPlan[]

  @@map("clinics")
}

enum Plan {
  BASIC
  PRO
  CLINIC
}

model User {
  id         String   @id @default(cuid())
  supabaseId String   @unique
  clinicId   String
  email      String
  firstName  String
  lastName   String
  role       Role     @default(DOCTOR)
  specialty  String?
  avatarUrl  String?
  phone      String?
  isActive   Boolean  @default(true)
  color      String   @default("#3b82f6")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Google Calendar
  googleCalendarToken   String?
  googleRefreshToken    String?
  googleCalendarEmail   String?
  googleCalendarEnabled Boolean @default(false)
  services              String[] @default([])

  clinic          Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  records         MedicalRecord[]
  primaryPatients Patient[]       @relation("PrimaryDoctor")
  treatments      TreatmentPlan[]

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  RECEPTIONIST
  READONLY
}

model Patient {
  id                 String        @id @default(cuid())
  clinicId           String
  patientNumber      String
  firstName          String
  lastName           String
  email              String?
  phone              String?
  dob                DateTime?
  gender             Gender        @default(OTHER)
  bloodType          String?
  address            String?
  insuranceProvider  String?
  insurancePolicy    String?
  allergies          String[]      @default([])
  chronicConditions  String[]      @default([])
  currentMedications String[]      @default([])
  tags               String[]      @default([])
  notes              String?
  status             PatientStatus @default(ACTIVE)
  primaryDoctorId    String?

  // Portal del paciente
  portalToken       String?   @unique
  portalTokenExpiry DateTime?

  // Datos fiscales para CFDI
  rfcPaciente      String?
  regimenFiscalPac String?
  cpPaciente       String?
  razonSocialPac   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic        Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  primaryDoctor User?           @relation("PrimaryDoctor", fields: [primaryDoctorId], references: [id])
  appointments  Appointment[]
  records       MedicalRecord[]
  invoices      Invoice[]
  files         PatientFile[]
  treatments    TreatmentPlan[]

  @@unique([clinicId, patientNumber])
  @@map("patients")
}

enum Gender {
  M
  F
  OTHER
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Appointment {
  id                    String            @id @default(cuid())
  clinicId              String
  patientId             String
  doctorId              String
  type                  String
  date                  DateTime
  startTime             String
  endTime               String
  durationMins          Int               @default(30)
  room                  String?
  status                AppointmentStatus @default(PENDING)
  notes                 String?
  reminderSent          Boolean           @default(false)
  confirmedAt           DateTime?
  cancelledAt           DateTime?
  cancelReason          String?
  googleCalendarEventId String?
  price                 Float?
  stripePaymentIntentId String?
  isPaid                Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  clinic    Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient   Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor    User               @relation(fields: [doctorId], references: [id])
  invoice   Invoice?
  reminders WhatsAppReminder[]

  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model MedicalRecord {
  id            String   @id @default(cuid())
  clinicId      String
  patientId     String
  doctorId      String
  visitDate     DateTime @default(now())
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  diagnoses     Json?
  vitals        Json?
  specialtyData Json?
  isPrivate     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User    @relation(fields: [doctorId], references: [id])

  @@map("medical_records")
}

// ── IDEA 2: Treatment Plans ────────────────────────────────────────────────
model TreatmentPlan {
  id          String              @id @default(cuid())
  clinicId    String
  patientId   String
  doctorId    String
  name        String              // "Ortodoncia 18 meses", "Rehabilitación periodontal"
  description String?
  totalSessions Int               @default(1)
  sessionIntervalDays Int         @default(30) // expected days between sessions
  totalCost   Float               @default(0)
  status      TreatmentStatus     @default(ACTIVE)
  startDate   DateTime            @default(now())
  endDate     DateTime?           // expected end date
  // Follow-up tracking
  lastFollowUpSent DateTime?       // last time we sent a follow-up WhatsApp
  nextExpectedDate DateTime?       // next expected session date
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  clinic   Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient  Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor   User               @relation(fields: [doctorId], references: [id])
  sessions TreatmentSession[]

  @@map("treatment_plans")
}

model TreatmentSession {
  id            String          @id @default(cuid())
  treatmentId   String
  sessionNumber Int
  notes         String?
  completedAt   DateTime?       // null = not yet done
  createdAt     DateTime        @default(now())

  treatment TreatmentPlan @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@map("treatment_sessions")
}

enum TreatmentStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  PAUSED
}

// ── CFDI records ──────────────────────────────────────────────────────────
model CfdiRecord {
  id              String   @id @default(cuid())
  clinicId        String
  invoiceId       String?
  facturapiId     String
  uuid            String   @unique
  tipoComprobante String   @default("I")
  receptor        Json
  conceptos       Json
  total           Float
  status          String   @default("valid")
  xmlUrl          String?
  pdfUrl          String?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("cfdi_records")
}

model Invoice {
  id            String        @id @default(cuid())
  clinicId      String
  patientId     String
  appointmentId String?       @unique
  invoiceNumber String
  items         Json
  subtotal      Float
  discount      Float         @default(0)
  total         Float
  paid          Float         @default(0)
  balance       Float
  status        InvoiceStatus @default(PENDING)
  paymentMethod String?
  notes         String?
  dueDate       DateTime?
  paidAt        DateTime?
  cfdiUuid      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  payments    Payment[]

  @@unique([clinicId, invoiceNumber])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Float
  method    String
  reference String?
  notes     String?
  paidAt    DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ClinicSchedule {
  id        String  @id @default(cuid())
  clinicId  String
  dayOfWeek Int
  enabled   Boolean @default(true)
  openTime  String  @default("09:00")
  closeTime String  @default("18:00")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, dayOfWeek])
  @@map("clinic_schedules")
}

model PatientFile {
  id        String   @id @default(cuid())
  patientId String
  name      String
  url       String
  size      Int?
  mimeType  String?
  category  String?
  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_files")
}

model InventoryItem {
  id          String   @id @default(cuid())
  clinicId    String
  name        String
  description String?
  category    String
  emoji       String   @default("📦")
  quantity    Int      @default(0)
  minQuantity Int      @default(5)
  unit        String   @default("pza")
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic  Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  history InventoryHistory[]

  @@map("inventory_items")
}

model InventoryHistory {
  id        String   @id @default(cuid())
  itemId    String
  change    Int
  reason    String?
  createdAt DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("inventory_history")
}

model WhatsAppReminder {
  id            String                 @id @default(cuid())
  clinicId      String
  appointmentId String
  type          String
  status        WhatsAppReminderStatus @default(PENDING)
  sentAt        DateTime?
  errorMsg      String?
  scheduledFor  DateTime
  createdAt     DateTime               @default(now())

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("whatsapp_reminders")
}

enum WhatsAppReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}
