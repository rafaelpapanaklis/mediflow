generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clinic {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  specialty   String // @deprecated — usar category en su lugar
  category    ClinicCategory @default(OTHER)
  country     String    @default("MX")
  city        String?
  address     String?
  phone       String?
  email       String?
  logoUrl     String?
  taxId       String?
  isPublic    Boolean   @default(false)
  description String?
  plan        Plan      @default(PRO)
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // WhatsApp
  waPhoneNumberId  String?
  waAccessToken    String?
  waConnected      Boolean @default(false)
  waReminderActive Boolean @default(true)
  waReminder24h    Boolean @default(true)
  waReminder1h     Boolean @default(false)
  waReminderMsg    String?

  // Google Calendar — clinic-level shared calendar
  googleCalendarToken     String?   // access token of the admin who connected
  googleRefreshToken      String?   // refresh token
  googleCalendarEmail     String?   // google account email
  googleCalendarEnabled   Boolean   @default(false)
  googleClinicCalendarId  String?   // ID of the "clinic" calendar in Google

  // CFDI / Facturación SAT
  facturApiOrgId    String?
  rfcEmisor         String?
  regimenFiscal     String?
  cpEmisor          String?
  facturApiEnabled  Boolean @default(false)

  // Subscription / Billing
  subscriptionStatus   String?   // active, trialing, past_due, cancelled
  subscriptionId       String?   // legacy — Stripe/MP subscription ID
  nextBillingDate      DateTime?
  monthlyPrice         Float?    @default(0)
  // Stripe subscription billing
  stripeCustomerId       String?   // Stripe Customer ID for the clinic owner
  stripeSubscriptionId   String?   // Stripe Subscription ID (recurring)
  stripePaymentMethodId  String?   // default payment method
  // PayPal
  paypalSubscriptionId   String?   // PayPal subscription ID (recurring)
  paypalEmail            String?   // PayPal email for manual payments
  // Payment preferences
  preferredPaymentMethod String?   // stripe, paypal, transfer, oxxo
  recallMonths         Int       @default(6)  // months before annual reminder
  recallActive         Boolean   @default(false)
  googlePlaceId        String?   // Google Maps Place ID for fetching reviews

  // Landing page
  landingActive       Boolean  @default(false)
  landingThemeColor   String?  @default("#2563eb")
  landingCoverUrl     String?
  landingGallery      String[] @default([])
  landingTestimonials Json?
  landingFaqs         Json?
  landingServices     Json?
  landingHours        Json?
  landingWhatsapp     String?
  landingInstagram    String?
  landingFacebook     String?
  landingTiktok       String?
  landingMapEmbed     String?
  landingTagline      String?

  // AI Assistant usage tracking
  aiTokensUsed  Int      @default(0)
  aiTokensLimit Int      @default(50000)
  aiLastResetAt DateTime @default(now())

  // Telemedicine
  teleEnabled         Boolean  @default(false)
  teleCommissionPct   Float    @default(15)
  dailyApiKey         String?

  users        User[]
  patients     Patient[]
  appointments Appointment[]
  records      MedicalRecord[]
  invoices     Invoice[]
  schedules    ClinicSchedule[]
  inventory    InventoryItem[]
  reminders    WhatsAppReminder[]
  cfdis        CfdiRecord[]
  treatments    TreatmentPlan[]
  paymentPlans  PaymentPlan[]
  consentForms         ConsentForm[]
  periodontalRecords   PeriodontalRecord[]
  subscriptionInvoices SubscriptionInvoice[]
  files                PatientFile[]
  auditLogs            AuditLog[]
  beforeAfterPhotos    BeforeAfterPhoto[]
  servicePackages      ServicePackage[]
  formulaRecords       FormulaRecord[]
  bodyMapAnnotations   BodyMapAnnotation[]
  walkInQueue          WalkInQueue[]
  resourceBookings     ResourceBooking[]
  procedureCatalog     ProcedureCatalog[]

  @@map("clinics")
}

enum ClinicCategory {
  DENTAL
  MEDICINE
  NUTRITION
  PSYCHOLOGY
  DERMATOLOGY
  AESTHETIC_MEDICINE
  HAIR_RESTORATION
  BEAUTY_CENTER
  BROW_LASH
  MASSAGE
  LASER_HAIR_REMOVAL
  HAIR_SALON
  ALTERNATIVE_MEDICINE
  NAIL_SALON
  SPA
  PHYSIOTHERAPY
  PODIATRY
  OTHER
}

enum Plan {
  BASIC
  PRO
  CLINIC
}

model User {
  id         String   @id @default(cuid())
  supabaseId String
  clinicId   String
  email      String
  firstName  String
  lastName   String
  role       Role     @default(DOCTOR)
  specialty  String?
  avatarUrl  String?
  phone      String?
  isActive   Boolean  @default(true)
  color      String   @default("#3b82f6")
  lastLogin  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Google Calendar
  googleCalendarToken   String?
  googleRefreshToken    String?
  googleCalendarEmail   String?
  googleCalendarEnabled Boolean @default(false)
  services              String[] @default([])

  // Stripe Connect (telemedicine payments)
  stripeAccountId     String?
  stripeOnboarded     Boolean  @default(false)
  teleconsultPrice    Float?

  clinic          Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  records         MedicalRecord[]
  primaryPatients Patient[]       @relation("PrimaryDoctor")
  treatments          TreatmentPlan[]
  periodontalRecords  PeriodontalRecord[]
  auditLogs           AuditLog[]

  @@unique([supabaseId, clinicId])
  @@index([supabaseId])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  RECEPTIONIST
  READONLY
}

model Patient {
  id                 String        @id @default(cuid())
  clinicId           String
  patientNumber      String
  firstName          String
  lastName           String
  email              String?
  phone              String?
  dob                DateTime?
  gender             Gender        @default(OTHER)
  bloodType          String?
  address            String?
  insuranceProvider  String?
  insurancePolicy    String?
  allergies          String[]      @default([])
  chronicConditions  String[]      @default([])
  currentMedications String[]      @default([])
  tags               String[]      @default([])
  notes              String?
  status             PatientStatus @default(ACTIVE)
  isChild            Boolean   @default(false)  // true = dentición temporal
  primaryDoctorId    String?

  // Portal del paciente
  portalToken       String?   @unique
  portalTokenExpiry DateTime?

  // Datos fiscales para CFDI
  rfcPaciente      String?
  regimenFiscalPac String?
  cpPaciente       String?
  razonSocialPac   String?

  // Extended fields for multi-category
  skinPhototype     String?
  hairType          String?
  nailCondition     String?
  painAreas         Json?
  mobilityNotes     String?
  diabeticRisk      String?
  doshaType         String?
  preferredPressure Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic        Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  primaryDoctor User?           @relation("PrimaryDoctor", fields: [primaryDoctorId], references: [id])
  appointments  Appointment[]
  records       MedicalRecord[]
  invoices      Invoice[]
  files         PatientFile[]
  treatments    TreatmentPlan[]
  paymentPlans  PaymentPlan[]
  consentForms        ConsentForm[]
  periodontalRecords  PeriodontalRecord[]
  beforeAfterPhotos   BeforeAfterPhoto[]
  formulaRecords      FormulaRecord[]
  bodyMapAnnotations  BodyMapAnnotation[]
  packageRedemptions  PackageRedemption[]

  @@unique([clinicId, patientNumber])
  @@map("patients")
}

enum Gender {
  M
  F
  OTHER
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Appointment {
  id                    String            @id @default(cuid())
  clinicId              String
  patientId             String
  doctorId              String
  type                  String
  date                  DateTime
  startTime             String
  endTime               String
  durationMins          Int               @default(30)
  room                  String?
  status                AppointmentStatus @default(PENDING)
  notes                 String?
  reminderSent          Boolean           @default(false)
  confirmedAt           DateTime?
  cancelledAt           DateTime?
  cancelReason          String?
  googleCalendarEventId String?
  price                 Float?
  stripePaymentIntentId String?
  isPaid                Boolean           @default(false)

  // Telemedicine
  mode              AppointmentMode @default(IN_PERSON)
  teleRoomId        String?
  teleRoomUrl       String?
  teleDoctorToken   String?
  telePatientToken  String?
  teleRecordingUrl  String?
  paymentStatus     String?
  paymentAmount     Float?
  stripePaymentId   String?
  stripeSessionId   String?

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  clinic    Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient   Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor    User               @relation(fields: [doctorId], references: [id])
  invoice   Invoice?
  reminders WhatsAppReminder[]

  @@map("appointments")
}

enum AppointmentMode {
  IN_PERSON
  TELECONSULTATION
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model MedicalRecord {
  id            String   @id @default(cuid())
  clinicId      String
  patientId     String
  doctorId      String
  visitDate     DateTime @default(now())
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  diagnoses     Json?
  vitals        Json?
  specialtyData Json?
  isPrivate     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User    @relation(fields: [doctorId], references: [id])

  @@map("medical_records")
}

// ── IDEA 2: Treatment Plans ────────────────────────────────────────────────
model TreatmentPlan {
  id          String              @id @default(cuid())
  clinicId    String
  patientId   String
  doctorId    String
  name        String              // "Ortodoncia 18 meses", "Rehabilitación periodontal"
  description String?
  totalSessions Int               @default(1)
  sessionIntervalDays Int         @default(30) // expected days between sessions
  totalCost   Float               @default(0)
  status      TreatmentStatus     @default(ACTIVE)
  startDate   DateTime            @default(now())
  endDate     DateTime?           // expected end date
  // Follow-up tracking
  lastFollowUpSent DateTime?       // last time we sent a follow-up WhatsApp
  nextExpectedDate DateTime?       // next expected session date
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  clinic   Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient  Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor   User               @relation(fields: [doctorId], references: [id])
  sessions TreatmentSession[]

  @@map("treatment_plans")
}

model TreatmentSession {
  id            String          @id @default(cuid())
  treatmentId   String
  sessionNumber Int
  notes         String?
  completedAt   DateTime?       // null = not yet done
  createdAt     DateTime        @default(now())

  treatment TreatmentPlan @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@map("treatment_sessions")
}

enum TreatmentStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  PAUSED
}

// ── CFDI records ──────────────────────────────────────────────────────────
model CfdiRecord {
  id              String   @id @default(cuid())
  clinicId        String
  invoiceId       String?
  facturapiId     String
  uuid            String   @unique
  tipoComprobante String   @default("I")
  receptor        Json
  conceptos       Json
  total           Float
  status          String   @default("valid")
  xmlUrl          String?
  pdfUrl          String?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("cfdi_records")
}

model Invoice {
  id            String        @id @default(cuid())
  clinicId      String
  patientId     String
  appointmentId String?       @unique
  invoiceNumber String
  items         Json
  subtotal      Float
  discount      Float         @default(0)
  total         Float
  paid          Float         @default(0)
  balance       Float
  status        InvoiceStatus @default(PENDING)
  paymentMethod String?
  notes         String?
  dueDate       DateTime?
  paidAt        DateTime?
  cfdiUuid      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  payments    Payment[]

  @@unique([clinicId, invoiceNumber])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Float
  method    String
  reference String?
  notes     String?
  paidAt    DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ClinicSchedule {
  id        String  @id @default(cuid())
  clinicId  String
  dayOfWeek Int
  enabled   Boolean @default(true)
  openTime  String  @default("09:00")
  closeTime String  @default("18:00")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, dayOfWeek])
  @@map("clinic_schedules")
}

model PatientFile {
  id          String       @id @default(cuid())
  patientId   String
  clinicId    String
  uploadedBy  String?
  name        String
  url         String
  size        Int?
  mimeType    String?
  category    FileCategory @default(OTHER)
  toothNumber Int?
  notes       String?
  takenAt     DateTime?
  createdAt   DateTime     @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("patient_files")
}

enum FileCategory {
  XRAY_PERIAPICAL
  XRAY_PANORAMIC
  XRAY_BITEWING
  XRAY_OCCLUSAL
  PHOTO_FRONTAL
  PHOTO_LATERAL
  PHOTO_OCCLUSAL_UPPER
  PHOTO_OCCLUSAL_LOWER
  PHOTO_INTRAORAL
  CONSENT_FORM
  OTHER
}

// ── Payment Plans ─────────────────────────────────────────────────────
model PaymentPlan {
  id           String           @id @default(cuid())
  clinicId     String
  patientId    String
  invoiceId    String?
  name         String
  totalAmount  Float
  downPayment  Float            @default(0)
  installments Int              @default(12)
  frequency    PaymentFrequency @default(MONTHLY)
  startDate    DateTime         @default(now())
  notes        String?
  status       PlanStatus       @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  clinic   Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient  Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payments PlanPayment[]

  @@map("payment_plans")
}

model PlanPayment {
  id          String    @id @default(cuid())
  planId      String
  installment Int
  amount      Float
  dueDate     DateTime
  paidAt      DateTime?
  method      String?
  notes       String?
  createdAt   DateTime  @default(now())

  plan PaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_payments")
}

enum PaymentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum PlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  OVERDUE
}

// ── Consent Forms ─────────────────────────────────────────────────────
model ConsentForm {
  id           String    @id @default(cuid())
  clinicId     String
  patientId    String
  procedure    String
  content      String
  signedAt     DateTime?
  signatureUrl String?
  token        String    @unique
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("consent_forms")
}


// ── Periodontal Records ────────────────────────────────────────────────────────
model PeriodontalRecord {
  id          String   @id @default(cuid())
  patientId   String
  clinicId    String
  doctorId    String
  recordedAt  DateTime @default(now())
  // JSON: { "11": { "buccal": [2,3,2], "lingual": [2,2,3], "bleeding": [false,true,false], "furcation": 0 }, ... }
  measurements Json
  plaquIndex  Float?
  bleedingIndex Float?
  notes       String?
  createdAt   DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor  User    @relation(fields: [doctorId], references: [id])

  @@map("periodontal_records")
}

// ── Subscription Invoices (for admin billing) ──────────────────────────────────
model SubscriptionInvoice {
  id          String   @id @default(cuid())
  clinicId    String
  amount      Float
  currency    String   @default("MXN")
  status      String   @default("pending") // pending, paid, failed
  method      String?  // stripe, mercadopago, transfer, deposit
  reference   String?  // payment reference/ID
  periodStart DateTime
  periodEnd   DateTime
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("subscription_invoices")
}


// ── Audit Log ─────────────────────────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  clinicId   String
  userId     String
  entityType String   // "patient" | "appointment" | "invoice" | "record"
  entityId   String
  action     String   // "create" | "update" | "delete" | "view"
  changes    Json?    // { field: { before, after } }
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([clinicId, entityType, entityId])
  @@index([clinicId, createdAt])
  @@map("audit_logs")
}


model InventoryItem {
  id          String   @id @default(cuid())
  clinicId    String
  name        String
  description String?
  category    String
  emoji       String   @default("📦")
  quantity    Int      @default(0)
  minQuantity Int      @default(5)
  unit        String   @default("pza")
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic  Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  history InventoryHistory[]

  @@map("inventory_items")
}

model InventoryHistory {
  id        String   @id @default(cuid())
  itemId    String
  change    Int
  reason    String?
  createdAt DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("inventory_history")
}

model WhatsAppReminder {
  id            String                 @id @default(cuid())
  clinicId      String
  appointmentId String?   // null for non-appointment reminders (recalls)
  patientPhone  String?   // for recall reminders without appointment
  message       String?   // message sent
  type          String    @default("APPOINTMENT") // APPOINTMENT | RECALL
  status        WhatsAppReminderStatus @default(PENDING)
  sentAt        DateTime?
  errorMsg      String?
  scheduledFor  DateTime  @default(now())
  patientReply  String?
  repliedAt     DateTime?
  createdAt     DateTime               @default(now())

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("whatsapp_reminders")
}

enum WhatsAppReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

// ── Multi-category models ─────────────────────────────────────────────────────

model BeforeAfterPhoto {
  id          String   @id @default(cuid())
  clinicId    String
  patientId   String
  category    String   // "before" | "after"
  angle       String   // "front", "left", "right", "top"
  sessionId   String?
  url         String
  takenAt     DateTime @default(now())
  notes       String?
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  @@index([patientId, category])
  @@index([clinicId])
  @@map("before_after_photos")
}

model ServicePackage {
  id              String   @id @default(cuid())
  clinicId        String
  name            String
  description     String?
  totalSessions   Int
  price           Float
  validDays       Int      @default(365)
  bodyZone        String?
  isActive        Boolean  @default(true)
  clinic          Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  redemptions     PackageRedemption[]
  @@index([clinicId])
  @@map("service_packages")
}

model PackageRedemption {
  id            String   @id @default(cuid())
  packageId     String
  patientId     String
  clinicId      String
  purchasedAt   DateTime @default(now())
  expiresAt     DateTime
  sessionsUsed  Int      @default(0)
  totalSessions Int
  status        String   @default("ACTIVE")
  package       ServicePackage @relation(fields: [packageId], references: [id])
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  @@index([patientId])
  @@index([clinicId])
  @@map("package_redemptions")
}

model FormulaRecord {
  id          String   @id @default(cuid())
  clinicId    String
  patientId   String
  type        String   // "hair_color", "lash_extension", "brow_tint", "herbal"
  formula     Json
  notes       String?
  appliedAt   DateTime @default(now())
  appliedBy   String?
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  @@index([patientId, type])
  @@index([clinicId])
  @@map("formula_records")
}

model BodyMapAnnotation {
  id          String   @id @default(cuid())
  clinicId    String
  patientId   String
  recordId    String?
  mapType     String   // "full_body", "face", "scalp", "feet_dorsal", "feet_plantar"
  annotations Json
  createdAt   DateTime @default(now())
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  @@index([patientId])
  @@index([clinicId])
  @@map("body_map_annotations")
}

model WalkInQueue {
  id          String    @id @default(cuid())
  clinicId    String
  patientId   String?
  patientName String
  service     String
  priority    Int       @default(0)
  status      String    @default("WAITING")
  assignedTo  String?
  joinedAt    DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  clinic      Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  @@index([clinicId, status])
  @@map("walk_in_queue")
}

model ResourceBooking {
  id            String   @id @default(cuid())
  clinicId      String
  appointmentId String?
  resourceType  String
  resourceName  String
  startTime     DateTime
  endTime       DateTime
  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  @@index([clinicId, resourceType, startTime])
  @@map("resource_bookings")
}

model ProcedureCatalog {
  id           String   @id @default(cuid())
  clinicId     String
  name         String
  code         String?  // SAT code for CFDI
  category     String   // "general", "dental", "aesthetic", etc.
  basePrice    Float
  duration     Int?     // minutes
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  @@index([clinicId, isActive])
  @@map("procedure_catalog")
}
