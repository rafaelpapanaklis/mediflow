/// Implante dental — entidad central, dispositivo médico clase III.
/// brand / lotNumber / placedAt son INMUTABLES por defecto. Cualquier
/// UPDATE en estos campos requiere flag de sesión + justificación ≥20
/// chars (validado por trigger SQL `protect_implant_traceability`).
/// DELETE prohibido por trigger `block_implant_delete` — "remover" =
/// `currentStatus = REMOVED` + `removalReason`.
model Implant {
  id        String @id @default(uuid())
  patientId String
  clinicId  String

  // Posición anatómica (FDI 11..48)
  toothFdi Int

  // ── Trazabilidad COFEPRIS clase III (INMUTABLE) ─────────────────────
  brand            ImplantBrand
  brandCustomName  String? // requerido si brand = OTRO
  modelName        String
  diameterMm       Decimal                  @db.Decimal(3, 1) // 3.0..7.0
  lengthMm         Decimal                  @db.Decimal(4, 1) // 6.0..18.0
  connectionType   ImplantConnectionType
  surfaceTreatment ImplantSurfaceTreatment?
  lotNumber        String // CRÍTICO COFEPRIS
  manufactureDate  DateTime?
  expiryDate       DateTime?
  // ────────────────────────────────────────────────────────────────────

  placedAt         DateTime // CRÍTICO COFEPRIS
  placedByDoctorId String

  protocol        ImplantProtocol
  currentStatus   ImplantStatus   @default(PLACED)
  statusUpdatedAt DateTime        @default(now())

  // Removal (en lugar de delete) — §1.10
  removedAt              DateTime?
  removalReason          String? // length ≥20 si REMOVED
  removalSurgeryRecordId String?

  notes String? @db.Text

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // NO deletedAt — semántica de "borrar" es REMOVED

  patient        Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)
  clinic         Clinic  @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  placedByDoctor User    @relation("ImplantPlacedBy", fields: [placedByDoctorId], references: [id], onDelete: Restrict)

  surgicalRecord         ImplantSurgicalRecord?
  healingPhase           ImplantHealingPhase?
  secondStage            ImplantSecondStageSurgery?
  prostheticPhase        ImplantProstheticPhase?
  complications          ImplantComplication[]
  followUps              ImplantFollowUp[]
  consents               ImplantConsent[]
  passport               ImplantPassport?
  // Cross-module: evaluaciones periimplantares que apuntan a este
  // implante via la FK que aporta A2 cross-módulos.
  periImplantAssessments PeriImplantAssessment[]    @relation("ImplantPeriAssessments")

  @@index([patientId, currentStatus])
  @@index([clinicId, currentStatus])
  @@index([clinicId, placedAt(sort: Desc)])
  @@index([brand, lotNumber]) // queries de recall por lote
  @@index([toothFdi])
  @@map("implants")
}

/// Cirugía de colocación. 1:1 con Implant. Datos quirúrgicos completos
/// + lote del pilar de cicatrización (COFEPRIS).
model ImplantSurgicalRecord {
  id        String @id @default(uuid())
  implantId String @unique

  performedAt           DateTime
  asaClassification     ASAClassification
  prophylaxisAntibiotic Boolean           @default(false)
  prophylaxisDrug       String?
  hba1cIfDiabetic       Decimal?          @db.Decimal(3, 1)

  insertionTorqueNcm        Int
  isqMesiodistal            Int
  isqVestibulolingual       Int
  boneDensity               LekholmZarbDensity
  ridgeWidthMm              Decimal?           @db.Decimal(3, 1)
  ridgeHeightMm             Decimal?           @db.Decimal(4, 1)
  flapType                  String
  drillingProtocol          String
  healingAbutmentLot        String? // CRÍTICO COFEPRIS si protocolo 1-stage
  healingAbutmentDiameterMm Decimal?           @db.Decimal(3, 1)
  healingAbutmentHeightMm   Decimal?           @db.Decimal(3, 1)

  sutureMaterial            String?
  sutureRemovalScheduledAt  DateTime?
  intraoperativePhotoFileId String?
  postOpInstructions        String?   @db.Text
  durationMinutes           Int

  complications String? @db.Text // intraoperatorias

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  implant             Implant      @relation(fields: [implantId], references: [id], onDelete: Cascade)
  intraoperativePhoto PatientFile? @relation("ImplantSurgicalIntraoperativePhoto", fields: [intraoperativePhotoFileId], references: [id], onDelete: SetNull)

  @@index([performedAt])
  @@map("implant_surgical_records")
}

/// Fase de osteointegración. 1:1 con Implant. Cicatrización + ISQ.
model ImplantHealingPhase {
  id        String @id @default(uuid())
  implantId String @unique

  startedAt             DateTime
  expectedDurationWeeks Int

  isqAt2Weeks Int?
  isqAt4Weeks Int?
  isqAt8Weeks Int?
  isqLatest   Int?
  isqLatestAt DateTime?

  completedAt DateTime?
  notes       String?   @db.Text

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  implant Implant @relation(fields: [implantId], references: [id], onDelete: Cascade)

  @@map("implant_healing_phases")
}

/// 2ª cirugía (descubrimiento) en protocolo 2-stage. 1:1 con Implant.
/// El lote del pilar de cicatrización es CRÍTICO COFEPRIS.
model ImplantSecondStageSurgery {
  id        String @id @default(uuid())
  implantId String @unique

  performedAt               DateTime
  technique                 String
  healingAbutmentLot        String // CRÍTICO COFEPRIS
  healingAbutmentDiameterMm Decimal  @db.Decimal(3, 1)
  healingAbutmentHeightMm   Decimal  @db.Decimal(3, 1)

  isqAtUncovering Int?
  durationMinutes Int

  notes String? @db.Text

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  implant Implant @relation(fields: [implantId], references: [id], onDelete: Cascade)

  @@map("implant_second_stage_surgeries")
}

/// Fase protésica. 1:1 con Implant. Lotes de pilar / prótesis / tornillo
/// son críticos COFEPRIS. Al guardarse exitosamente se dispara la
/// generación automática de ImplantPassport (carnet PDF).
model ImplantProstheticPhase {
  id        String @id @default(uuid())
  implantId String @unique

  // Pilar
  abutmentType          AbutmentType
  abutmentBrand         String?
  abutmentLot           String // CRÍTICO COFEPRIS
  abutmentDiameterMm    Decimal?     @db.Decimal(3, 1)
  abutmentHeightMm      Decimal?     @db.Decimal(3, 1)
  abutmentAngulationDeg Int?
  abutmentTorqueNcm     Int

  // Prótesis
  prosthesisType     ProsthesisType
  prosthesisMaterial ProsthesisMaterial
  prosthesisLabName  String
  prosthesisLabLot   String // CRÍTICO COFEPRIS

  // Tornillo (si screw-retained)
  screwLot       String?
  screwTorqueNcm Int?

  // Carga / entrega
  immediateLoading       Boolean   @default(false)
  provisionalDeliveredAt DateTime?
  definitiveDeliveredAt  DateTime?
  prosthesisDeliveredAt  DateTime
  occlusionScheme        String?

  notes String? @db.Text

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  implant Implant @relation(fields: [implantId], references: [id], onDelete: Cascade)

  @@map("implant_prosthetic_phases")
}

/// Complicación periimplantaria. N:1 con Implant. Al crearse cambia
/// `Implant.currentStatus` a COMPLICATION. Si tipo es biológico
/// (mucositis / peri-implantitis) y módulo Periodoncia activo, también
/// dispara `createPeriImplantAssessment` (STUB en MVP).
model ImplantComplication {
  id        String @id @default(uuid())
  implantId String
  clinicId  String
  patientId String

  detectedAt  DateTime
  type        ImplantComplicationType
  severity    String // leve | moderada | severa
  description String                  @db.Text

  // Hallazgos clínicos (si tipo biológico)
  bopAtDiagnosis         Boolean?
  pdMaxAtDiagnosisMm     Decimal? @db.Decimal(3, 1)
  suppurationAtDiagnosis Boolean?
  radiographicBoneLossMm Decimal? @db.Decimal(3, 1)

  treatmentPlan String? @db.Text

  // Resolución
  resolvedAt DateTime?
  outcome    String? // exitoso | parcial | fracaso | en_curso

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  implant Implant @relation(fields: [implantId], references: [id], onDelete: Cascade)

  @@index([implantId, detectedAt(sort: Desc)])
  @@index([clinicId, type])
  @@index([clinicId, resolvedAt])
  @@map("implant_complications")
}

/// Visita de mantenimiento periimplantario. N:1 con Implant. Pérdida
/// ósea radiográfica acumulada se compara contra criterios Albrektsson
/// 1986 (1.5mm año 1, <0.2mm/año después).
model ImplantFollowUp {
  id        String @id @default(uuid())
  implantId String
  clinicId  String

  milestone   ImplantFollowUpMilestone
  scheduledAt DateTime?
  performedAt DateTime?

  bopPresent      Boolean?
  pdMaxMm         Decimal? @db.Decimal(3, 1)
  suppuration     Boolean?
  mobility        Boolean?
  occlusionStable Boolean?

  radiographicBoneLossMm   Decimal? @db.Decimal(3, 1)
  meetsAlbrektssonCriteria Boolean?
  radiographFileId         String?

  nextControlAt DateTime?
  notes         String?   @db.Text

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  implant        Implant      @relation(fields: [implantId], references: [id], onDelete: Cascade)
  radiographFile PatientFile? @relation("ImplantFollowUpRadiograph", fields: [radiographFileId], references: [id], onDelete: SetNull)

  @@index([implantId, scheduledAt])
  @@index([clinicId, performedAt])
  @@index([scheduledAt, performedAt]) // overdue queries
  @@map("implant_follow_ups")
}

/// Consentimiento informado. N:1 con Implant. Tipo SURGERY / BONE_AUGMENTATION
/// / QR_PUBLIC. La firma del paciente puede guardarse como base64 inline o
/// como PatientFile.
model ImplantConsent {
  id        String @id @default(uuid())
  implantId String
  patientId String
  doctorId  String

  consentType   ImplantConsentType
  text          String             @db.Text
  acceptedRisks Json? // { mronj: true, sinus_perforation: true, ... }

  signedAt              DateTime?
  patientSignatureImage String?   @db.Text // base64 inline o referencia
  signedFileId          String? // si se subió como archivo escaneado

  revokedAt        DateTime?
  revocationReason String?   @db.Text

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  implant    Implant      @relation(fields: [implantId], references: [id], onDelete: Cascade)
  patient    Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor     User         @relation("ImplantConsentDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  signedFile PatientFile? @relation("ImplantConsentSigned", fields: [signedFileId], references: [id], onDelete: SetNull)

  passportsLinkedByQrConsent ImplantPassport[] @relation("ImplantPassportQrConsent")

  @@index([implantId, consentType])
  @@map("implant_consents")
}

/// Carnet del implante (PDF licencia horizontal landscape). 1:1 con
/// Implant. Auto-generado al finalizar fase protésica. Cualquier mutación
/// posterior dispara regeneración (`regeneratedAt`).
/// QR público es OPT-IN — requiere ImplantConsent type=QR_PUBLIC.
model ImplantPassport {
  id        String @id @default(uuid())
  implantId String @unique

  generatedAt   DateTime  @default(now())
  regeneratedAt DateTime?

  pdfFileId          String?
  patientPhotoFileId String?

  qrPublicEnabled   Boolean @default(false)
  qrPublicConsentId String?
  qrToken           String? @unique

  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  implant          Implant         @relation(fields: [implantId], references: [id], onDelete: Cascade)
  pdfFile          PatientFile?    @relation("ImplantPassportPdf", fields: [pdfFileId], references: [id], onDelete: SetNull)
  patientPhotoFile PatientFile?    @relation("ImplantPassportPhoto", fields: [patientPhotoFileId], references: [id], onDelete: SetNull)
  qrPublicConsent  ImplantConsent? @relation("ImplantPassportQrConsent", fields: [qrPublicConsentId], references: [id], onDelete: SetNull)

  @@map("implant_passports")
}

