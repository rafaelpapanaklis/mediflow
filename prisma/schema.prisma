enum PatientFlowStatus {
  WAITING
  IN_CHAIR
  CHECKOUT
  COMPLETED
}

// ─── PatientFlow (cross-cutting clinical-shared) — G16 ──────────────────────
//
// Estado del paciente cuando está hoy en clínica: WAITING → IN_CHAIR →
// CHECKOUT → COMPLETED. Vive en clinical-shared porque todas las especialidades
// muestran el badge "En clínica" en su sidebar derecha.

model PatientFlow {
  id        String @id @default(uuid())
  clinicId  String
  patientId String

  status        PatientFlowStatus
  /// Sillón asignado, libre: "Sillón 2".
  chair         String?
  /// Cita relacionada (opcional — el flow puede activarse sin cita formal).
  appointmentId String?

  enteredAt     DateTime  @default(now())
  exitedAt      DateTime?
  triggeredById String?
  triggeredBy   User?     @relation("PatientFlowTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)

  notes String?

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, status, exitedAt])
  @@index([patientId, enteredAt(sort: Desc)])
  @@map("patient_flow_entries")
}

