// ── ClinicalPhoto ───────────────────────────────────────────────────────────
//
// Foto clínica unificada para los 5 módulos. Almacena URL pública en
// Supabase storage bucket `clinical-photos` (RLS por clinicId). Soporta
// thumbnail aparte para grids ligeros y soft-delete (deletedAt).
model ClinicalPhoto {
  id           String             @id @default(cuid())
  clinicId     String
  patientId    String
  module       ClinicalModule
  toothFdi     Int? // 11–48 (permanente) o 51–85 (temporal)
  photoType    ClinicalPhotoType
  stage        ClinicalPhotoStage
  capturedAt   DateTime           @default(now())
  capturedBy   String
  blobUrl      String
  thumbnailUrl String?
  notes        String?
  // Anotaciones libres sobre la foto (eg. "diente 51 erupcionando").
